# KOSH POS - Environment Variables

# The base URL of your REST API
# This is used for all REST API calls (products, sales, transactions, etc.)
VITE_API_URL=http://localhost:4000

# Google OAuth Client ID - Get this from https://console.cloud.google.com/
# Required for the Google Sign-In button on the login page
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

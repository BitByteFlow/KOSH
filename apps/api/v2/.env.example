# Server Configuration
PORT=3001
NODE_ENV=development

# Health Check Configuration
# Version for health endpoint
npm_package_version=1.0.0

# Sentry Configuration (Error & Performance Monitoring)
# Get your DSN from https://sentry.io
SENTRY_DSN=

# Sample rates for performance monitoring (0.0 - 1.0)
# Production: Lower values reduce costs (0.1 = 10% of traces)
# Development: Use 1.0 for full visibility
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# CORS Configuration
# Comma-separated list of allowed origins (e.g., http://localhost:3000,https://app.example.com)
# Use "*" to allow all origins (not recommended for production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/kosh

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Sentry Configuration (optional)
# SENTRY_DSN=

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  INITIAL_CAPITAL
  ADDITIONAL_CAPITAL
  WITHDRAWAL
  SALE_INCOME
  PURCHASE
  DEBT_PAID
  CREDIT_RECEIVED
  EXPENSES
}

enum PaymentType {
  CASH
  ONLINE
  CREDIT
}

enum ProductStatus {
  ACTIVE
  IN_ACTIVE
  OUT_OF_STOCK
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

model User {
  id            String   @id @default(uuid())
  username      String
  email         String   @unique
  googleId      String?  @unique
  image         String?
  contactNumber String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products       Product[]
  sales          Sale[]
  purchases      Purchase[]
  transactions   AccountTransaction[]
  creditAccounts CreditAccount[]
  categories     Category[]
}

model Category {
  id     String @id @default(uuid())
  name   String
  userId String
  user   User   @relation(fields: [userId], references: [id])

  products Product[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, name])
  @@index([userId])
}

model Product {
  id     String        @id @default(uuid())
  name   String
  status ProductStatus @default(ACTIVE)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  variants ProductVariant[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([categoryId])
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  sku          String
  barcode      String
  costPrice    Decimal @db.Decimal(12, 2)
  sellingPrice Decimal @db.Decimal(12, 2)
  stock        Int     @default(0)

  attributes     VariantAttribute[]
  purchaseItems  PurchaseItem[]
  saleItems      SaleItem[]
  // stockMovements StockMovement[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([sku])
  @@unique([barcode])
  @@index([productId])
}

model VariantAttribute {
  id        String         @id @default(uuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  name  String
  value String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([variantId])
}

model Purchase {
  id           String  @id @default(uuid())
  supplierName String
  email        String?
  contact      String?

  total      Decimal       @db.Decimal(12, 2)
  amountPaid Decimal       @db.Decimal(12, 2)
  balanceDue Decimal       @db.Decimal(12, 2)
  dueDate    DateTime?
  status     PaymentStatus @default(PENDING)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items        PurchaseItem[]
  transactions AccountTransaction[] @relation("PurchaseTransactions")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
}

model PurchaseItem {
  id         String @id @default(uuid())
  purchaseId String
  variantId  String

  quantity Int
  price    Decimal @db.Decimal(12, 2)

  purchase Purchase       @relation(fields: [purchaseId], references: [id])
  variant  ProductVariant @relation(fields: [variantId], references: [id])

  @@index([purchaseId])
  @@index([variantId])
}

model Sale {
  id       String  @id @default(uuid())
  total    Decimal @db.Decimal(12, 2)
  discount Decimal @db.Decimal(12, 2)
  profit   Decimal @db.Decimal(12, 2)

  paymentType PaymentType
  creditId    String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  credit       CreditAccount?       @relation(fields: [creditId], references: [id])
  items        SaleItem[]
  transactions AccountTransaction[] @relation("SalesTransactions")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
  @@index([creditId])
}

model SaleItem {
  id        String @id @default(uuid())
  saleId    String
  variantId String

  quantity  Int
  sellPrice Decimal @db.Decimal(12, 2)
  costPrice Decimal @db.Decimal(12, 2)

  sale    Sale           @relation(fields: [saleId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([saleId])
  @@index([variantId])
}

model CreditAccount {
  id            String  @id @default(uuid())
  customerName  String
  email         String?
  contactNumber String?
  balance       Decimal @db.Decimal(12, 2)
  isActive      Boolean @default(true)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  sales        Sale[]
  transactions AccountTransaction[] @relation("CreditAccountTransactions")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
}

model AccountTransaction {
  id     String          @id @default(uuid())
  type   TransactionType
  amount Decimal         @db.Decimal(12, 2)
  note   String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  saleId String?
  sale   Sale?   @relation("SalesTransactions", fields: [saleId], references: [id])

  purchaseId String?
  purchase   Purchase? @relation("PurchaseTransactions", fields: [purchaseId], references: [id])

  creditAccountId String?
  creditAccount   CreditAccount? @relation("CreditAccountTransactions", fields: [creditAccountId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([saleId])
  @@index([purchaseId])
  @@index([creditAccountId])
}


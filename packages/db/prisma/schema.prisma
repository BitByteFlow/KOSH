generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Store {
  id        String   @id @default(uuid())
  name      String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  categories     Category[]
  products       Product[]
  purchases      Purchase[]
  sales          Sale[]
  creditAccounts CreditAccount[]
  dailyBalances  DailyBalance[]
  settings       Settings?
}

enum Role {
  ADMIN
  CASHIER
}

model User {
  id       String  @id @default(uuid())
  username String
  email    String  @unique
  googleId String? @unique
  role     Role    @default(ADMIN)
  image     String?

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  sales         Sale[]
  transactions  AccountTransaction[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id                String   @id @default(uuid())
  lowStockThreshold Int      @default(10)
  autoArchive       Boolean  @default(false)
  emailReports      Boolean  @default(true)
  pushNotifications Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Category {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  storeId  String
  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([storeId, name])
  @@index([storeId])
}

model Product {
  id         String    @id @default(uuid())
  name       String
  categoryId String
  storeId    String
  store      Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  category   Category  @relation(fields: [categoryId], references: [id])

  // userId   String
  // user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  variants ProductVariant[]

  // @@index([userId])
  @@index([categoryId])
}

model ProductVariant {
  id             String             @id @default(uuid())
  productId      String
  sku            String             @unique
  barcode        String             @unique
  costPrice      Decimal            @db.Decimal(12, 2)
  sellingPrice   Decimal            @db.Decimal(12, 2)
  stock          Int                @default(0)
  status         ProductStatus      @default(ACTIVE)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  lowStock       Boolean            @default(false)
  product        Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchasesItems PurchaseItem[]
  saleItems      SaleItem[]
  attributes     VariantAttribute[]
  notifications  Notification[]

  @@index([productId])
}

model VariantAttribute {
  id        String         @id @default(uuid())
  variantId String
  name      String
  value     String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
}

model Purchase {
  id           String              @id @default(uuid())
  supplierName String
  email        String?
  contact      String?
  total        Decimal             @db.Decimal(12, 2)
  amountPaid   Decimal             @db.Decimal(12, 2)
  balanceDue   Decimal             @db.Decimal(12, 2)
  dueDate      DateTime?
  status       PaymentStatus       @default(PENDING)
  userId       String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  deletedAt    DateTime?
  transaction  AccountTransaction?
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items        PurchaseItem[]

  @@index([userId])
}

model PurchaseItem {
  id         String         @id @default(uuid())
  purchaseId String
  quantity   Int
  price      Decimal        @db.Decimal(12, 2)
  variantId  String
  purchase   Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id])

  @@index([purchaseId])
  @@index([variantId])
}

model Sale {
  id                 String              @id @default(uuid())
  total              Decimal             @db.Decimal(12, 2)
  discount           Decimal             @db.Decimal(12, 2)
  profit             Decimal             @db.Decimal(12, 2)
  paymentType        PaymentType
  creditId           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  accountTransaction AccountTransaction?
  credit             CreditAccount?      @relation(fields: [creditId], references: [id])

  userId String
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  SaleItem[]

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([creditId])
}

model SaleItem {
  id        String         @id @default(uuid())
  quantity  Int
  sellPrice Decimal        @db.Decimal(12, 2)
  costPrice Decimal        @db.Decimal(12, 2)
  saleId    String
  variantId String
  sale      Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@index([saleId])
  @@index([variantId])
}

model CreditAccount {
  id            String               @id @default(uuid())
  customerName  String
  email         String?
  contactNumber String?
  balance       Decimal              @db.Decimal(12, 2)
  isActive      Boolean              @default(true)
  userId        String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  deletedAt     DateTime?
  transactions  AccountTransaction[]
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales         Sale[]

  @@index([userId])
}

model AccountTransaction {
  id              String          @id @default(uuid())
  type            TransactionType
  amount          Decimal         @db.Decimal(12, 2)
  note            String?
  userId          String
  saleId          String?         @unique
  purchaseId      String?         @unique
  creditAccountId String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  dailyBalanceId  String?
  creditAccount   CreditAccount?  @relation(fields: [creditAccountId], references: [id])
  dailyBalance    DailyBalance?   @relation(fields: [dailyBalanceId], references: [id])
  purchase        Purchase?       @relation(fields: [purchaseId], references: [id])
  sale            Sale?           @relation(fields: [saleId], references: [id])
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([saleId])
  @@index([purchaseId])
  @@index([creditAccountId])
}

model DailyBalance {
  id           String               @id @default(uuid())
  date         DateTime             @default(now())
  openingCash  Decimal              @db.Decimal(12, 2)
  closingCash  Decimal              @db.Decimal(12, 2)
  totalSales   Decimal              @default(0) @db.Decimal(12, 2)
  totalExpense Decimal              @default(0) @db.Decimal(12, 2)
  totalCashIn  Decimal              @default(0) @db.Decimal(12, 2)
  totalCashOut Decimal              @default(0) @db.Decimal(12, 2)
  userId       String
  transactions AccountTransaction[]
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

enum TransactionType {
  INITIAL_CAPITAL
  ADDITIONAL_CAPITAL
  WITHDRAWAL
  SALE_INCOME
  PURCHASE
  DEBT_PAID
  CREDIT_RECEIVED
  EXPENSES
  DEBT
}

enum PaymentType {
  CASH
  ONLINE
  CREDIT
}

enum ProductStatus {
  ACTIVE
  IN_ACTIVE
  OUT_OF_STOCK
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum NotificationType {
  LOW_STOCK
  NEW_FEATURE_ADDED
}

model Notification {
  id      String           @id @default(uuid())
  userId  String
  type    NotificationType
  message String
  isRead  Boolean          @default(false)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  isGlobal  Boolean         @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([variantId])
}

generator client {
  provider        = "prisma-client-js"
  output          = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CASHIER
}

enum ProductStatus {
  ACTIVE
  IN_ACTIVE
  OUT_OF_STOCK
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentType {
  CASH
  ONLINE
  CREDIT
}

enum TransactionType {
  INITIAL_CAPITAL
  ADDITIONAL_CAPITAL
  CREDIT
  WITHDRAWAL
  SALE_INCOME
  PURCHASE
  DEBT_PAID
  CREDIT_RECEIVED
  EXPENSES
  DEBT
  ADJUSTMENT
}

enum NotificationType {
  LOW_STOCK
  NEW_FEATURE_ADDED
  SYSTEM_ALERT
  JOIN_REQUEST
  JOIN_ACCEPTED
  JOIN_REJECTED
}

enum StoreJoinRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum StockMovementType {
  SALE
  PURCHASE
  ADJUSTMENT
  RETURN
  DAMAGED
  OPENING_STOCK
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String
  googleId  String   @unique
  image     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdStores Store[]            @relation("StoreCreator")
  storeMember   StoreMember?
  purchases     Purchase[]
  sales         Sale[]
  notifications Notification[]
  joinRequests  StoreJoinRequest[]
}

model Store {
  id          String   @id @default(uuid())
  name        String
  description String?
  address     String?
  phone       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creatorId String
  creator   User   @relation("StoreCreator", fields: [creatorId], references: [id])

  members             StoreMember[]
  categories          Category[]
  products            Product[]
  variants            ProductVariant[]
  purchases           Purchase[]
  sales               Sale[]
  creditAccounts      CreditAccount[]
  accountTransactions AccountTransaction[]
  dailyBalances       DailyBalance[]
  settings            Settings?
  joinRequests        StoreJoinRequest[]
}

model StoreMember {
  id       String  @id @default(uuid())
  storeId  String
  userId   String  @unique
  role     Role    @default(CASHIER)
  isActive Boolean @default(true)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storeId, userId])
}

model StoreJoinRequest {
  id        String                 @id @default(uuid())
  storeId   String
  userId    String
  status    StoreJoinRequestStatus @default(PENDING)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storeId, userId])
  @@index([storeId])
  @@index([userId])
}

model Settings {
  id                String   @id @default(uuid())
  lowStockThreshold Int      @default(10)
  autoArchive       Boolean  @default(false)
  emailReports      Boolean  @default(true)
  pushNotifications Boolean  @default(false)
  currency          String   @default("NRP")
  timeZone          String   @default("UTC")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Category {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  products Product[]

  @@unique([storeId, name])
  @@index([storeId])
}

model Product {
  id          String    @id @default(uuid())
  name        String
  sku         String?
  description String?
  categoryId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  category Category         @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]

  @@unique([storeId, name])
  @@index([storeId])
  @@index([categoryId])
}

model ProductVariant {
  id           String        @id @default(uuid())
  productId    String
  storeId      String
  sku          String
  barcode      String
  costPrice    Decimal       @db.Decimal(12, 2)
  sellingPrice Decimal       @db.Decimal(12, 2)
  stock        Int           @default(0)
  status       ProductStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  lowStock     Boolean       @default(false)

  product       Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  store         Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]
  attributes    VariantAttribute[]
  notifications Notification[]

  @@unique([storeId, sku])
  @@unique([storeId, barcode])
  @@index([productId])
  @@index([storeId])
}

model VariantAttribute {
  id        String   @id @default(uuid())
  variantId String
  name      String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
}

model Purchase {
  id           String        @id @default(uuid())
  supplierName String
  email        String?
  contact      String?
  total        Decimal       @db.Decimal(12, 2)
  amountPaid   Decimal       @db.Decimal(12, 2)
  balanceDue   Decimal       @db.Decimal(12, 2)
  dueDate      DateTime?
  status       PaymentStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  transaction AccountTransaction?
  items       PurchaseItem[]

  @@index([storeId, createdAt])
  @@index([userId])
}

model PurchaseItem {
  id         String  @id @default(uuid())
  purchaseId String
  variantId  String
  quantity   Int
  price      Decimal @db.Decimal(12, 2)

  purchase Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id])

  @@index([purchaseId])
  @@index([variantId])
}

model Sale {
  id          String      @id @default(uuid())
  total       Decimal     @db.Decimal(12, 2)
  subtotal    Decimal     @db.Decimal(12, 2)
  profit      Decimal     @db.Decimal(12, 2)
  discount    Decimal     @db.Decimal(12, 2)
  paymentType PaymentType
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  creditId String?
  credit   CreditAccount? @relation(fields: [creditId], references: [id])

  transaction AccountTransaction?
  items       SaleItem[]

  @@index([storeId, createdAt])
  @@index([userId])
  @@index([creditId])
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  variantId String
  quantity  Int
  sellPrice Decimal @db.Decimal(12, 2)
  costPrice Decimal @db.Decimal(12, 2)

  sale    Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([saleId])
  @@index([variantId])
}

model CreditAccount {
  id            String    @id @default(uuid())
  customerName  String
  email         String?
  contactNumber String?
  balance       Decimal   @db.Decimal(12, 2)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  transactions AccountTransaction[]
  sales        Sale[]

  @@index([storeId])
}

model AccountTransaction {
  id        String          @id @default(uuid())
  type      TransactionType
  amount    Decimal         @db.Decimal(12, 2)
  note      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  saleId          String?        @unique
  sale            Sale?          @relation(fields: [saleId], references: [id])
  purchaseId      String?        @unique
  purchase        Purchase?      @relation(fields: [purchaseId], references: [id])
  creditAccountId String?
  creditAccount   CreditAccount? @relation(fields: [creditAccountId], references: [id])
  dailyBalanceId  String?
  dailyBalance    DailyBalance?  @relation(fields: [dailyBalanceId], references: [id])

  @@index([storeId, createdAt])
  @@index([saleId])
  @@index([purchaseId])
  @@index([creditAccountId])
  @@index([dailyBalanceId])
}

model DailyBalance {
  id           String  @id @default(uuid())
  date         String
  openingCash  Decimal @db.Decimal(12, 2)
  closingCash  Decimal @db.Decimal(12, 2)
  totalSales   Decimal @default(0) @db.Decimal(12, 2)
  totalExpense Decimal @default(0) @db.Decimal(12, 2)
  totalCashIn  Decimal @default(0) @db.Decimal(12, 2)
  totalCashOut Decimal @default(0) @db.Decimal(12, 2)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  transactions AccountTransaction[]

  @@unique([storeId, date])
  @@index([storeId, date])
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  message   String
  isRead    Boolean          @default(false)
  isGlobal  Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([variantId])
  @@index([isRead])
}

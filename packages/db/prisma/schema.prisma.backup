generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CASHIER
  MANAGER
}

enum ProductStatus {
  ACTIVE
  IN_ACTIVE
  OUT_OF_STOCK
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentType {
  CASH
  ONLINE
  CREDIT
}

enum TransactionType {
  INITIAL_CAPITAL
  ADDITIONAL_CAPITAL
  WITHDRAWAL
  SALE_INCOME
  PURCHASE
  DEBT_PAID
  CREDIT_RECEIVED
  EXPENSES
  DEBT
  ADJUSTMENT
}

enum NotificationType {
  LOW_STOCK
  NEW_FEATURE_ADDED
  SYSTEM_ALERT
}

enum StockMovementType {
  SALE
  PURCHASE
  ADJUSTMENT
  RETURN
  DAMAGED
  OPENING_STOCK
}

model Store {
  id        String   @id @default(uuid())
  name      String
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  members        StoreMember[]
  categories     Category[]
  products       Product[]
  purchases      Purchase[]
  sales          Sale[]
  creditAccounts CreditAccount[]
  dailyBalances  DailyBalance[]
  transactions   AccountTransaction[]
  settings       Settings?

  @@index([creatorId])
}

model User {
  id       String  @id @default(uuid())
  username String
  email    String  @unique
  googleId String? @unique
  image    String?

  memberships   StoreMember[]
  createdStores Store[]       @relation("StoreCreator")

  sales         Sale[]
  notifications Notification[]
  purchases     Purchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model StoreMember {
  id        String   @id @default(uuid())
  userId    String
  storeId   String
  role      Role     @default(CASHIER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([storeId])
  @@index([userId])
}

model Settings {
  id                String   @id @default(uuid())
  lowStockThreshold Int      @default(10)
  autoArchive       Boolean  @default(false)
  emailReports      Boolean  @default(true)
  pushNotifications Boolean  @default(false)
  currency          String   @default("NRP")
  timeZone          String   @default("UTC")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model Category {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  storeId  String
  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([storeId, name])
  @@index([storeId])
}

model Product {
  id         String @id @default(uuid())
  name       String
  categoryId String
  storeId    String

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category Category         @relation(fields: [categoryId], references: [id])
  variants ProductVariant[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([categoryId])
  @@index([storeId])
}

model ProductVariant {
  id           String        @id @default(uuid())
  productId    String
  storeId      String
  sku          String
  barcode      String
  costPrice    Decimal       @db.Decimal(12, 2)
  sellingPrice Decimal       @db.Decimal(12, 2)
  stock        Int           @default(0)
  status       ProductStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  lowStock     Boolean       @default(false)

  product        Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  store          Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  purchasesItems PurchaseItem[]
  saleItems      SaleItem[]
  attributes     VariantAttribute[]
  notifications  Notification[]

  @@unique([storeId, sku])
  @@unique([storeId, barcode])
  @@index([productId])
  @@index([storeId])
}

model VariantAttribute {
  id        String   @id @default(uuid())
  variantId String
  name      String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
}

model Purchase {
  id           String        @id @default(uuid())
  supplierName String
  email        String?
  contact      String?
  total        Decimal       @db.Decimal(12, 2)
  amountPaid   Decimal       @db.Decimal(12, 2)
  balanceDue   Decimal       @db.Decimal(12, 2)
  dueDate      DateTime?
  status       PaymentStatus @default(PENDING)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  transaction AccountTransaction?
  items       PurchaseItem[]

  @@index([storeId, createdAt])
  @@index([userId])
}

model PurchaseItem {
  id         String  @id @default(uuid())
  purchaseId String
  quantity   Int
  price      Decimal @db.Decimal(12, 2)
  variantId  String

  purchase Purchase       @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id])

  @@index([purchaseId])
  @@index([variantId])
}

model Sale {
  id          String      @id @default(uuid())
  total       Decimal     @db.Decimal(12, 2)
  subtotal    Decimal     @db.Decimal(12, 2)
  discount    Decimal     @db.Decimal(12, 2)
  profit      Decimal     @db.Decimal(12, 2)
  paymentType PaymentType

  creditId String?
  credit   CreditAccount? @relation(fields: [creditId], references: [id])

  userId  String
  user    User   @relation(fields: [userId], references: [id])
  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  accountTransaction AccountTransaction?
  items              SaleItem[]

  @@index([storeId, createdAt])
  @@index([userId])
  @@index([creditId])
}

model SaleItem {
  id        String  @id @default(uuid())
  quantity  Int
  sellPrice Decimal @db.Decimal(12, 2)
  costPrice Decimal @db.Decimal(12, 2)
  saleId    String
  variantId String

  sale    Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([saleId])
  @@index([variantId])
}

model CreditAccount {
  id            String  @id @default(uuid())
  customerName  String
  email         String?
  contactNumber String?
  balance       Decimal @db.Decimal(12, 2)
  isActive      Boolean @default(true)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  transactions AccountTransaction[]
  sales        Sale[]

  @@index([storeId])
}

model AccountTransaction {
  id     String          @id @default(uuid())
  type   TransactionType
  amount Decimal         @db.Decimal(12, 2)
  note   String?

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  saleId          String?        @unique
  sale            Sale?          @relation(fields: [saleId], references: [id])
  purchaseId      String?        @unique
  purchase        Purchase?      @relation(fields: [purchaseId], references: [id])
  creditAccountId String?
  creditAccount   CreditAccount? @relation(fields: [creditAccountId], references: [id])
  dailyBalanceId  String?
  dailyBalance    DailyBalance?  @relation(fields: [dailyBalanceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, createdAt])
  @@index([saleId])
  @@index([purchaseId])
  @@index([creditAccountId])
  @@index([dailyBalanceId])
}

model DailyBalance {
  id           String  @id @default(uuid())
  date         String // Format: "YYYY-MM-DD" ensures uniqueness per day
  openingCash  Decimal @db.Decimal(12, 2)
  closingCash  Decimal @db.Decimal(12, 2)
  totalSales   Decimal @default(0) @db.Decimal(12, 2)
  totalExpense Decimal @default(0) @db.Decimal(12, 2)
  totalCashIn  Decimal @default(0) @db.Decimal(12, 2)
  totalCashOut Decimal @default(0) @db.Decimal(12, 2)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  transactions AccountTransaction[]

  @@unique([storeId, date])
  @@index([storeId, date])
}

model Notification {
  id       String           @id @default(uuid())
  type     NotificationType
  message  String
  isRead   Boolean          @default(false)
  isGlobal Boolean          @default(false)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([variantId])
  @@index([isRead])
}
